<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FX.InventoryViewController">
   <children>
      <Label layoutX="31.0" layoutY="29.0" text="Load inventory" />
      <Button layoutX="120.0" layoutY="25.0" mnemonicParsing="false" onAction="#handleRefresh" text="Refresh" />
      <TableView fx:id="inventoryTable" AnchorPane.bottomAnchor="45.0" AnchorPane.leftAnchor="9.0" AnchorPane.rightAnchor="9.0" AnchorPane.topAnchor="69.0">
        <columns>
          <TableColumn fx:id="itemCode" prefWidth="75.0" text="Code" />
          <TableColumn fx:id="itemName" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="itemPrice" prefWidth="75.0" text="Price" />
            <TableColumn fx:id="itemQuantity" prefWidth="75.0" text="Quantity" />
            <TableColumn fx:id="itemCategory" prefWidth="75.0" text="Category" />
            <TableColumn fx:id="itemDate" prefWidth="75.0" text="Date" />
            <TableColumn fx:id="itemImage" prefWidth="75.0" text="Image" />
            <TableColumn fx:id="itemBrand" prefWidth="75.0" text="Brand" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label layoutX="300.0" text="Total Item Count : " AnchorPane.bottomAnchor="10.0" />
      <Label layoutX="458.0" text="Total Value : " AnchorPane.bottomAnchor="10.0" />
      <Label fx:id="totalCountLabel" layoutX="398.0" text="0" AnchorPane.bottomAnchor="10.0" />
      <Label fx:id="totalValueLabel" layoutX="527.0" text="0" AnchorPane.bottomAnchor="10.0" />
   </children>
</AnchorPane>
